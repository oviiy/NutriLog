.day {
  padding: 48rpx;
}
.day-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16rpx;
}
.day-date { 
  font-size: 34rpx; 
  font-weight: 600; 
  color: #1E3A8A;
}
.day-kcal { 
  color: #38BDF8; 
  font-weight: 600; 
  font-size: 32rpx;
}
.day-macros { 
  font-size: 26rpx; 
  margin-bottom: 8rpx;
}
.day-entries {
  font-size: 24rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  border: 4rpx dashed #E0F2FE;
  background: rgba(255, 255, 255, 0.5);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  display: block;
}

.empty-text {
  color: #7DD3FC;
  font-size: 28rpx;
}
