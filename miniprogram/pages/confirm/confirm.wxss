.raw .raw-text { 
  display: block; 
  margin-top: 12rpx; 
  font-size: 28rpx; 
  color: #475569;
}
.small { font-size: 24rpx; }

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 24rpx;
}
.card-header text:first-child {
  font-size: 30rpx;
  font-weight: 600;
  color: #0369A1;
}
.card-header .total { 
  font-weight: 500; 
  color: #38BDF8;
}

.picker-row {
  display: flex;
  gap: 20rpx;
  margin-top: 10rpx;
}
.picker-btn {
  background: #F0F9FF;
  color: #0369A1;
  padding: 20rpx 40rpx;
  border-radius: 100rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid #BAE6FD;
}

.quick-scales {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  gap: 12rpx;
}
.scale-btn {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  padding: 12rpx 0;
  background: #F8FAFC;
  color: #64748B;
  border-radius: 20rpx;
  border: 2rpx solid #E2E8F0;
}
.scale-btn.active {
  background: #E0F2FE;
  color: #0284C7;
  border-color: #7DD3FC;
  font-weight: 600;
}

.item {
  border-top: 2rpx dashed #F0F9FF;
  padding: 32rpx 0;
}
.item:first-of-type { border-top: none; padding-top: 0; }

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E3A8A;
  padding: 8rpx 0;
  margin-bottom: 12rpx;
}
.item-row {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}
.item-portion {
  flex: 1;
  color: #64748B;
  font-size: 28rpx;
  background: #F8FAFC;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
}
.item-num {
  width: 120rpx;
  text-align: right;
  font-variant-numeric: tabular-nums;
  padding: 12rpx 24rpx;
  background: #F0F9FF;
  border-radius: 20rpx;
  color: #0284C7;
  font-weight: 600;
  margin-left: 12rpx;
}
.item-num.small { width: 80rpx; font-size: 24rpx; padding: 8rpx 16rpx; }
.item-unit { color: #94A3B8; margin-left: 8rpx; font-size: 24rpx; }

.del {
  margin-left: 20rpx;
  width: 64rpx;
  height: 64rpx;
  background: #FEE2E2;
  border-radius: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #EF4444;
}

.macro-edit {
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 20rpx;
  background: #F8FAFC;
  padding: 16rpx;
  border-radius: 24rpx;
}
.macro-lbl {
  color: #94A3B8;
  font-size: 22rpx;
  font-weight: 600;
  margin-left: 8rpx;
}

.add-row {
  margin-top: 32rpx;
  text-align: center;
  color: #0284C7;
  font-size: 28rpx;
  font-weight: 600;
  padding: 24rpx;
  background: #F0F9FF;
  border: 2rpx dashed #BAE6FD;
  border-radius: 32rpx;
}

.notes text:last-child { 
  display: block; 
  margin-top: 12rpx; 
  font-size: 26rpx; 
  color: #64748B;
}

.footer {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
  padding-bottom: 48rpx;
}
.footer .btn-secondary, .footer .btn-primary {
  flex: 1;
}
.footer .btn-secondary {
  border-radius: 100rpx;
  padding: 28rpx;
  background: #FFFFFF;
  border: 2rpx solid #E2E8F0;
  color: #64748B;
}
