<view class="container">

  <!-- NutriCloud: Fluffy Header -->
  <view class="summary card">
    <view class="summary-top">
      <view class="summary-label" bindtap="onSetProfile">
        {{profile.weight}}kg / {{profile.height}}cm ✨
      </view>
      <view class="summary-date-box">
        <text class="summary-date-text">{{selectedDate}}</text>
        <view class="lang-toggle" bindtap="onToggleLang" style="margin-left: 20rpx">{{t.lang}}</view>
      </view>
    </view>
    
    <view class="kcal">
      <view class="kcal-main">
        <text class="kcal-num">{{day.totals.calories}}</text>
        <text class="kcal-unit">/ {{targets.calories}} kcal</text>
      </view>
      <view class="kcal-diff">
        {{day.totals.calories > targets.calories ? t.over : t.under}}
      </view>
    </view>

    <view class="macros">
      <view class="macro">
        <text class="macro-lbl">{{t.protein}}</text>
        <text class="macro-num {{day.totals.protein > targets.protein ? 'cap-over' : ''}}">{{day.totals.protein}} / {{targets.protein}}g</text>
      </view>
      <view class="macro">
        <text class="macro-lbl">{{t.carbs}}</text>
        <text class="macro-num {{day.totals.carbs > targets.carbs ? 'cap-over' : ''}}">{{day.totals.carbs}} / {{targets.carbs}}g</text>
      </view>
      <view class="macro">
        <text class="macro-lbl">{{t.fat}}</text>
        <text class="macro-num {{day.totals.fat > targets.fat ? 'cap-over' : ''}}">{{day.totals.fat}} / {{targets.fat}}g</text>
      </view>
    </view>
  </view>

  <!-- Fluffy Action Buttons -->
  <view class="actions">
    <view class="action-btn" bindtap="onSnap">
      <view class="icon">📸</view>
      <text class="action-title">{{t.snap}}</text>
      <text class="action-sub">{{t.snapSub}}</text>
    </view>

    <view class="action-btn" bindtap="onTextInput">
      <view class="icon">💬</view>
      <text class="action-title">{{t.describe}}</text>
      <text class="action-sub">{{t.describeSub}}</text>
    </view>
  </view>

  <!-- Sweet Logs Section -->
  <view class="section-title">{{t.logs}}</view>
  
  <view wx:if="{{day.entries.length}}">
    <view wx:for="{{day.entries}}" wx:key="id" class="log-item-container">
      <view class="swipe-actions-bg">
        <view class="swipe-btn edit" bindtap="onManualEdit" data-item="{{item}}">✏️</view>
        <view class="swipe-btn delete" bindtap="onDelete" data-id="{{item.id}}">🗑️</view>
      </view>
      <view class="log-card card" 
            style="transform: translateX({{item.offsetX || 0}}rpx)"
            data-id="{{item.id}}"
            bindtouchstart="onTouchStart"
            bindtouchmove="onTouchMove"
            bindtouchend="onTouchEnd">
        <view class="entry-head">
          <text class="entry-time">{{item.timeText}}</text>
          <text class="entry-kcal">{{item.subtotal.calories}} kcal</text>
        </view>
        <view wx:for="{{item.items}}" wx:for-item="food" wx:key="name" class="food-row">
          <text class="food-name">{{food.name}}</text>
          <text class="food-kcal">{{food.calories}}</text>
        </view>
      </view>
    </view>
  </view>
  <view wx:else class="empty-state card">
    <text class="empty-icon">🎈</text>
    <text class="empty-text">{{t.empty}}</text>
  </view>

  <!-- NutriCloud Fun Analysis Overlay -->
  <view class="analysis-overlay" wx:if="{{analyzing}}">
    <view class="analysis-box card">
      <view class="analysis-icon">☁️</view>
      <view class="analysis-scanner"></view>
      <text class="analysis-text">{{analysisMessage}}</text>
      <text class="analysis-sub">Feeding the cloud-brain...</text>
    </view>
  </view>

  <!-- Date Selector Slider -->
  <scroll-view scroll-x class="date-slider" scroll-with-animation scroll-into-view="d-{{selectedDate}}">
    <view wx:for="{{dateRange}}" wx:key="date" 
          class="date-item {{item.selected ? 'active' : ''}}" 
          id="d-{{item.date}}"
          bindtap="onSelectDate" 
          data-date="{{item.date}}">
      <text class="date-lbl">{{item.label}}</text>
    </view>
  </scroll-view>

  <!-- Fluffy Trends -->
  <view class="trend card">
    <view class="section-title" style="margin-bottom: 0;">{{t.trend}}</view>
    <view class="chart">
      <view wx:for="{{weeklyTrend}}" wx:key="subLabel" class="bar-col">
        <text class="bar-val" wx:if="{{item.kcal > 0}}">{{item.kcal}}</text>
        <view class="bar" style="height: {{item.height}}%"></view>
        <text class="bar-lbl">{{item.label}}</text>
        <text class="bar-sub">{{item.subLabel}}</text>
      </view>
    </view>
  </view>

</view>
